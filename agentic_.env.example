# =============================================================
# agentic-rag — Environment Variables
# =============================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# Never commit .env to version control.
# =============================================================


# -------------------------------------------------------------
# LLM Configuration
# -------------------------------------------------------------

# LLM provider: openai | anthropic
LLM_PROVIDER=openai

# OpenAI API key (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key-here

# OpenAI model (default: gpt-4o)
OPENAI_MODEL=gpt-4o

# Anthropic API key (required if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Anthropic model (default: claude-3-5-sonnet-20241022)
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# LLM temperature — low for factual Q&A (default: 0.1)
LLM_TEMPERATURE=0.1

# Max tokens in generated response (default: 1024)
# Higher than rag-pipeline to support multi-step reasoning
LLM_MAX_TOKENS=1024


# -------------------------------------------------------------
# Embedding Configuration
# -------------------------------------------------------------

# Embedding model (default: text-embedding-3-small)
EMBEDDING_MODEL=text-embedding-3-small


# -------------------------------------------------------------
# Chunking Configuration
# -------------------------------------------------------------

# Tokens per chunk — slightly smaller than rag-pipeline
# for improved retrieval precision in multi-hop scenarios
CHUNK_SIZE=384

# Overlapping tokens between chunks (default: 40)
CHUNK_OVERLAP=40


# -------------------------------------------------------------
# Vector Store Configuration (Pinecone)
# -------------------------------------------------------------

# Pinecone API key (required)
# Find this in your Pinecone console: https://app.pinecone.io
PINECONE_API_KEY=your-pinecone-api-key-here

# Pinecone index name (default: agentic-rag-meridian)
PINECONE_INDEX_NAME=agentic-rag-meridian

# Pinecone cloud provider: aws | gcp | azure
# Check your Pinecone console for your index's cloud provider
PINECONE_CLOUD=aws

# Pinecone region (e.g. us-east-1, us-west-2, eu-west-1)
# Check your Pinecone console for your index's region
PINECONE_REGION=us-east-1

# Force rebuild the Pinecone index on next run (default: false)
FORCE_REBUILD=false


# -------------------------------------------------------------
# Retrieval Configuration
# -------------------------------------------------------------

# Number of chunks to retrieve per query (default: 5)
RETRIEVAL_TOP_K=5

# Minimum similarity score to include a result (default: 0.3)
SIMILARITY_CUTOFF=0.3

# Minimum retrieval score before agent attempts re-retrieval (default: 0.35)
MIN_RETRIEVAL_SCORE=0.35


# -------------------------------------------------------------
# Agent Configuration
# -------------------------------------------------------------

# Maximum reasoning iterations before the agent gives up (default: 5)
MAX_AGENT_ITERATIONS=5


# -------------------------------------------------------------
# Memory Configuration
# -------------------------------------------------------------

# Maximum number of full turns to keep in memory (default: 10)
MAX_HISTORY_TURNS=10

# Trigger summarization of older turns at this count (default: 8)
# Must be less than MAX_HISTORY_TURNS
MEMORY_SUMMARY_THRESHOLD=8


# -------------------------------------------------------------
# Streamlit UI Configuration
# -------------------------------------------------------------

# Port for the Streamlit server (default: 8501)
STREAMLIT_PORT=8501
